# ============================================
# DATABASE — Neon PostgreSQL
# ============================================
# Obtenha a connection string em https://neon.com
# Formato: postgresql://user:password@host/db?sslmode=require
DATABASE_URL="postgresql://..."

# ============================================
# NEXTAUTH / AUTHENTICATION
# ============================================
# Gere um secret com: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# URL base da aplicação (produção)
# Ex: https://palpite-perfeito.vercel.app ou https://bolao.cesarmenegatti.com
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# ADMIN (seed inicial)
# ============================================
# Senha do usuário admin criado pelo seed
ADMIN_PASS=""

# ============================================
# DEVELOPMENT (opcional)
# ============================================
# Origens permitidas para dev local
# NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1
